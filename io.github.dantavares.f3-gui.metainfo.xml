<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.dantavares.f3-gui</id>

  <name>F3 GUI</name>
  <summary>Graphical interface for Fight Flash Fraud</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      F3 GUI is a graphical interface for the Fight Flash Fraud (f3) 
      command-line tools, which detect and correct fake USB drives and memory
      cards that report a larger capacity than they actually have.
    </p>
    <p>Features:</p>
    <ul>
      <li>Automatically detects removable storage devices</li>
      <li>Execute f3write to write test data to the device</li>
      <li>EExecute f3read to verify the integrity of the recorded data</li>
      <li>Run f3probe to probe the actual capabilities of the device</li>
      <li>Run f3fix to fix the partition table of fake devices</li>
      <li>It delivers a clear verdict: genuine or fake device</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.dantavares.f3-gui.desktop</launchable>

  <url type="homepage">https://github.com/dantavares/f3-gui</url>
